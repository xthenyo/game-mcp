{
  "mcpServers": {
    "game-mcp-team": {
      "command": "uv",
      "args": ["run", "--project", ".", "-m", "game_mcp.mcp_team"],
      "env": {}
    },
    "pixellab": {
      "url": "https://api.pixellab.ai/mcp",
      "headers": {
        "Authorization": "Bearer ${PIXELLAB_API_TOKEN}"
      }
    },
    "photoshop": {
      "command": "uvx",
      "args": ["--python", "3.10", "photoshop-mcp-server"],
      "env": {
        "PS_VERSION": "2021"
      }
    },
    "unity": {
      "command": "npx",
      "args": ["-y", "unity-mcp-cli", "connect"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
}
