{
  "mcpServers": {
    "game-mcp-team": {
      "command": "uv",
      "args": ["run", "--project", ".", "-m", "game_mcp.mcp_team"],
      "env": {}
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"],
      "env": {
        "RODIN_API_KEY": "${RODIN_API_KEY}"
      }
    },
    "photoshop": {
      "command": "npx",
      "args": ["-y", "photoshop-mcp@latest"]
    },
    "unity": {
      "command": "npx",
      "args": ["@anthropic/mcp-unity@latest"]
    }
  }
}
